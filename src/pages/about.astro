---
import Icon from "../components/Icon.astro";
import Layout from "../layouts/Layout.astro";
import QrCode from "../components/QrCode.astro";
import SocialNetworks from "../components/SocialNetworks.astro";
import ZenFade from "../components/zen/ZenFade.astro";
import ZenSlide from "../components/zen/ZenSlide.astro";
import ZenStagger from "../components/zen/ZenStagger.astro";
import BuyMeCoffee from "../components/client/BuyMeCoffee";
import {
  SITE_URL,
  GITHUB_URL,
  LINKEDIN_URL,
  X_URL,
  BLUESKY_URL,
  LINKFOLIO_URL,
  BUY_ME_COFFEE_URL,
} from "../consts";

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Alexandre Mogere',
  url: `${SITE_URL}/about`,
  jobTitle: 'Chapter Lead',
  worksFor: {
    '@type': 'Organization',
    name: 'Carrefour SI',
  },
  knowsAbout: ['JavaScript', 'TypeScript', 'Vue', 'React', 'Node.js', 'PHP', 'Symfony'],
  sameAs: [GITHUB_URL, LINKEDIN_URL, X_URL, BLUESKY_URL],
};
---

<Layout title="About" description="Alexandre Mogere - Chapter Lead at Carrefour SI. JavaScript, TypeScript, Vue, React, Node.js, PHP, and Symfony." headSchema={personSchema}>
  <ZenSlide direction="up" delay={200}>
    <blockquote>
      Hello, I'm <b>heristop</b>! <span class="about-info__wave">👋</span> I'm a Chapter Lead &
      Web Development Expert. I lead teams of developers building web applications,
      with a stack spanning JavaScript, TypeScript, Vue, React, Node.js, PHP, and Symfony.
      I care about technical leadership, architecture decisions, and keeping teams moving forward.
    </blockquote>
  </ZenSlide>

  <section class="about-info" aria-labelledby="personal-info-heading">
    <h2 class="sr-only" id="personal-info-heading">Personal Information</h2>
    <ZenStagger>
      <div class="about-info__grid">
        <ul class="about-info__list">
          <li class="about-info__item about-info__item--with-icon">
            <Icon name="briefcase" size={20} aria-hidden={true} />
            <div class="about-info__content">
              <div class="about-info__role">Chapter Lead</div>
              <span class="about-info__subtitle">@Carrefour SI</span>
            </div>
          </li>
          <li class="about-info__item"><Icon name="calendar" size={20} aria-hidden={true} /> 4 November</li>
          <li class="about-info__item"><Icon name="map-pin" size={20} aria-hidden={true} /> Paris, France</li>
        </ul>
        <div class="about-info__qr">
          <QrCode url={LINKFOLIO_URL} label="Link in bio" />
        </div>
      </div>
    </ZenStagger>
  </section>

  <ZenSlide direction="up" delay={800}>
    <h2 class="icon-heading social-heading">
      <Icon name="share-2" size={20} /> Zen Broadcasts
    </h2>
  </ZenSlide>

  <ZenFade delay={1000}>
    <SocialNetworks filter="socialnetwork" variant="compact" />
  </ZenFade>

  <ZenFade delay={1200}>
    <BuyMeCoffee client:visible url={BUY_ME_COFFEE_URL} />
  </ZenFade>
</Layout>

<style>
  .about-info__wave {
    display: inline-block;
    font-size: 1.5em;
    animation: wave 1.8s ease-in-out 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .about-info__wave {
      animation: none;
    }
  }

  .about-info__item--with-icon {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
  }

  .about-info__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.25rem;
  }

  @media screen and (width >= 40rem) {
    .about-info__item--with-icon {
      flex-direction: row;
      gap: 0.5rem;
    }

    .about-info__content {
      align-items: flex-start;
      text-align: left;
    }
  }

  .about-info__role {
    font-weight: 700;
  }

  .about-info__grid {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0.75rem;
  }

  .about-info__qr {
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: var(--surface-muted);
    box-shadow: var(--shadow-md);
    border-radius: var(--radius-md);
    padding: clamp(0.65rem, 2vw, 1rem);
  }

  @media screen and (width >= 40rem) {
    .about-info__grid {
      flex-direction: row;
      align-items: stretch;
      gap: 0.75rem;
    }

    .about-info__qr {
      flex-shrink: 0;
    }
  }

  @keyframes wave {
    0%,
    100% {
      transform: rotate(0deg);
    }
    20%,
    60% {
      transform: rotate(-25deg);
    }
    40%,
    80% {
      transform: rotate(25deg);
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const waveEmoji = document.querySelector(".about-info__wave") as HTMLElement;
    if (waveEmoji) {
      waveEmoji.addEventListener("mouseenter", () => {
        waveEmoji.style.animation = "none";
        setTimeout(() => {
          waveEmoji.style.animation = "wave 1.8s ease-in-out 3";
        }, 10);
      });
    }
  });
</script>
