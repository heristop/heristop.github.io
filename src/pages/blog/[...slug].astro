---
import "katex/dist/katex.min.css";
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BlogPostSchema from "../../components/BlogPostSchema.astro";
import BreadcrumbSchema from "../../components/BreadcrumbSchema.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Icon from "../../components/Icon.astro";
import Layout from "../../layouts/Layout.astro";
import PostTags from "../../components/client/PostTags";
import RecommendedPosts from "../../components/RecommendedPosts.astro";
import SocialShare from "../../components/SocialShare.astro";
import { BUY_ME_COFFEE_URL } from "../../consts";

const currentPostSlug = Astro.props.id;

export const getStaticPaths = async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
};
type Props = CollectionEntry<"blog">;

const post = Astro.props;
const { Content } = await render(post);
const {conclusion} = post.data;

const plainText = post.body ?? "";
const WORDS_PER_MINUTE = 200;
const words = plainText.split(/\s+/).length;
const readingTime = Math.ceil(words / WORDS_PER_MINUTE);

const allPostsCollection = await getCollection("blog");
const allPosts = allPostsCollection.toSorted(
  (postA, postB) => (postB.data.pubDate?.valueOf() ?? 0) - (postA.data.pubDate?.valueOf() ?? 0)
);

const currentIndex = allPosts.findIndex(item => item.id === currentPostSlug);

let previousPost;
if (currentIndex < allPosts.length - 1) {
  previousPost = allPosts[currentIndex + 1];
}

let nextPost;
if (currentIndex > 0) {
  nextPost = allPosts[currentIndex - 1];
}

const postUrl = `https://heristop.github.io/blog/${currentPostSlug}/`;

const postData = {
  ...post.data,
  isArticle: true,
  readingTime,
  tags: post.data.tags,
};

const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: 'Blog', url: '/blog' },
  { name: post.data.title, url: postUrl },
];
---

<BlogPostSchema
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  image={post.data.image}
  url={postUrl}
/>
<BreadcrumbSchema items={breadcrumbItems} />

<Layout {...postData}>
  <div class="post-page">
    <div class="post-page__meta zen-stagger">
      <div class="post-page__meta-info">
        <div class="post-page__date">
          <Icon name="calendar" size={16} class="post-page__date-icon" aria-hidden={true} />
          {post.data.pubDate && (
            <span
              class="post-page__date-text"
              transition:name={`post-date-${post.id}`}
            >
              <FormattedDate date={post.data.pubDate} showYear />
            </span>
          )}
        </div>
        <div class="post-page__reading-time">
          <Icon name="book" size={16} class="post-page__reading-icon" aria-hidden={true} />
          <span>{readingTime} min read</span>
        </div>
      </div>
      <div class="post-page__share">
        <SocialShare
          class="post-page__share-links"
          title={post.data.title}
          slug={currentPostSlug}
          minimal
        />
      </div>
    </div>

    {post.data.tags && post.data.tags.length > 0 && (
      <div class="post-page__tags-slot" transition:name={`post-tags-${post.id}`}>
        <PostTags client:load tags={post.data.tags} />
      </div>
    )}

    <Content />

    <div class="post-page__share-bottom">
      <SocialShare
        class="post-page__share-links"
        title={post.data.title}
        slug={currentPostSlug}
        supportUrl={BUY_ME_COFFEE_URL}
      />
    </div>

    <blockquote class="post-page__endquote">
      <RecommendedPosts {currentPostSlug} {conclusion} />
    </blockquote>
  </div>

  <div class="reading-progress" aria-hidden="true"></div>
  <button
    class="scroll-to-top"
    aria-label="Scroll to top"
    data-tooltip="↑ Back to top"
    data-tooltip-placement="left"
    data-scroll-top-fixed
    hidden
  >
    <Icon name="arrow-up" size={18} aria-hidden={true} />
  </button>

  <script type="module" is:inline define:vars={{ previousPost, nextPost }}>
    const NAVIGATION_DELAY = 150;
    const HINT_FADE_DELAY = 300;
    const HINT_DISPLAY_DURATION = 1000;
    const MOBILE_BREAKPOINT = 768;
    const TABLET_BREAKPOINT = 1024;
    const SWIPE_THRESHOLD = 100;
    const SWIPE_TIMEOUT = 500;
    const VERTICAL_THRESHOLD = 50;

    const isTouchDevice = 'ontouchstart' in globalThis || navigator.maxTouchPoints > 0;
    const isMobile = () => globalThis.innerWidth <= MOBILE_BREAKPOINT;
    const isTablet = () => globalThis.innerWidth > MOBILE_BREAKPOINT && globalThis.innerWidth <= TABLET_BREAKPOINT;
    const shouldUseTouchNavigation = () => isTouchDevice && (isMobile() || isTablet());

    const showNavigationHint = (direction) => {
      const targetPost = direction === 'previous' ? previousPost : nextPost;
      const hint = document.createElement('div');
      hint.className = `navigation-hint navigation-hint--${direction}`;
      hint.setAttribute('role', 'status');
      hint.setAttribute('aria-live', 'polite');

      const label = document.createElement('span');
      label.className = 'navigation-hint__label';
      label.textContent = direction === 'previous' ? '\u2190 Previous' : 'Next \u2192';
      hint.append(label);

      if (targetPost) {
        const title = document.createElement('span');
        title.className = 'navigation-hint__title';
        title.textContent = targetPost.data.title;
        hint.append(title);
      }

      document.body.append(hint);

      requestAnimationFrame(() => {
        hint.style.opacity = '0.88';
        hint.style.transform = 'translate(-50%, -50%)';
      });

      setTimeout(() => {
        hint.style.opacity = '0';
        hint.style.transform = 'translate(-50%, -50%) translateY(-10px)';
        setTimeout(() => {
          hint.remove();
        }, HINT_FADE_DELAY);
      }, HINT_DISPLAY_DURATION);
    };

    const buildIndicatorButtons = (shouldUseTouch) => {
      const indicatorHTML = [];
      const arrows = [];

      if (previousPost) {
        arrows.push(`
          <a
            class="post-nav-indicator post-nav-indicator--left"
            href="/blog/${previousPost.id}/"
            data-tooltip="\u2190 ${previousPost.data.title.replaceAll('"', '&quot;')}"
            data-tooltip-placement="left"
            aria-label="Previous post: ${previousPost.data.title.replaceAll('"', '&quot;')}"
          >\u2190</a>
        `);
      }

      if (nextPost) {
        arrows.push(`
          <a
            class="post-nav-indicator post-nav-indicator--right"
            href="/blog/${nextPost.id}/"
            data-tooltip="${nextPost.data.title.replaceAll('"', '&quot;')} \u2192"
            data-tooltip-placement="left"
            aria-label="Next post: ${nextPost.data.title.replaceAll('"', '&quot;')}"
          >\u2192</a>
        `);
      }

      if (arrows.length > 0) {
        indicatorHTML.push(`<div class="post-nav-arrows">${arrows.join('')}</div>`);

        const hintText = shouldUseTouch
          ? 'Swipe left/right to navigate reflections'
          : 'Use \u2190 \u2192 keys to navigate reflections';

        indicatorHTML.push(`
          <span
            class="post-nav-hint"
            role="status"
            aria-live="polite"
          >${hintText}</span>
        `);
      }

      return indicatorHTML;
    };

    const createNavigationIndicators = () => {
      const indicators = document.createElement('div');
      indicators.className = 'post-navigation-indicators';
      indicators.setAttribute('role', 'region');
      indicators.setAttribute('aria-label', 'Blog post navigation');

      const indicatorHTML = buildIndicatorButtons(shouldUseTouchNavigation());
      indicators.innerHTML = indicatorHTML.join('');
      document.body.append(indicators);
    };

    let navAbortController = null;

    const setupKeyboardNavigation = (isInputFocused, navigateToPost, signal) => {
      document.addEventListener('keydown', (event) => {
        if (isInputFocused() || event.ctrlKey || event.metaKey || event.altKey || event.shiftKey) {
          return;
        }

        switch (event.key) {
          case 'ArrowLeft': {
            if (previousPost) {
              event.preventDefault();
              navigateToPost('previous');
            }
            break;
          }

          case 'ArrowRight': {
            if (nextPost) {
              event.preventDefault();
              navigateToPost('next');
            }
            break;
          }
        }
      }, { signal });
    };

    const setupTouchNavigation = (isInputFocused, navigateToPost, signal) => {
      let touchStartX = 0;
      let touchStartY = 0;
      let touchStartTime = 0;

      document.addEventListener('touchstart', (event) => {
        if (isInputFocused()) {return;}

        const touch = event.touches[0];
        touchStartX = touch.clientX;
        touchStartY = touch.clientY;
        touchStartTime = Date.now();
      }, { passive: true, signal });

      document.addEventListener('touchend', (event) => {
        if (isInputFocused() || !touchStartX) {return;}

        const touch = event.changedTouches[0];
        const touchEndX = touch.clientX;
        const touchEndY = touch.clientY;
        const touchEndTime = Date.now();

        const deltaX = touchEndX - touchStartX;
        const deltaY = Math.abs(touchEndY - touchStartY);
        const timeDelta = touchEndTime - touchStartTime;

        touchStartX = 0;

        if (Math.abs(deltaX) > SWIPE_THRESHOLD &&
            deltaY < VERTICAL_THRESHOLD &&
            timeDelta < SWIPE_TIMEOUT) {

          if (deltaX > 0 && previousPost) {
            event.preventDefault();
            navigateToPost('previous');
          } else if (deltaX < 0 && nextPost) {
            event.preventDefault();
            navigateToPost('next');
          }
        }
      }, { passive: false, signal });
    };

    const initKeyboardNavigation = () => {
      if (navAbortController) {
        navAbortController.abort();
      }
      navAbortController = new AbortController();
      const { signal } = navAbortController;

      const existingPostNav = document.querySelector('.post-navigation-indicators');
      if (existingPostNav) {
        existingPostNav.remove();
      }

      const existingGlobalNav = document.querySelector('.global-navigation-indicators');
      if (existingGlobalNav) {
        existingGlobalNav.remove();
      }

      if (!previousPost && !nextPost) {return;}

      let inputFocused = false;

      const updateInputFocus = () => {
        const {activeElement} = document;
        inputFocused = activeElement && (
          activeElement.tagName === 'INPUT' ||
          activeElement.tagName === 'TEXTAREA' ||
          activeElement.tagName === 'SELECT' ||
          activeElement.contentEditable === 'true'
        );
      };

      document.addEventListener('focusin', updateInputFocus, { signal });
      document.addEventListener('focusout', updateInputFocus, { signal });

      const getInputFocused = () => inputFocused;

      const navigateToPost = (direction) => {
        const targetPost = direction === 'previous' ? previousPost : nextPost;
        if (targetPost) {
          showNavigationHint(direction);
          setTimeout(() => {
            globalThis.location.href = `/blog/${targetPost.id}/`;
          }, NAVIGATION_DELAY);
        }
      };

      if (!shouldUseTouchNavigation()) {
        setupKeyboardNavigation(getInputFocused, navigateToPost, signal);
      }

      if (shouldUseTouchNavigation()) {
        setupTouchNavigation(getInputFocused, navigateToPost, signal);
      }

      createNavigationIndicators();
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initKeyboardNavigation);
    } else {
      initKeyboardNavigation();
    }

    document.addEventListener('astro:page-load', initKeyboardNavigation);

    document.addEventListener('astro:page-load', () => {
      const { hash } = globalThis.location;
      if (hash) {
        const target = document.querySelector(hash);
        if (target) {
          requestAnimationFrame(() => {
            target.scrollIntoView({ behavior: 'smooth' });
          });
        }
      }
    });

    const initReadingProgress = () => {
      const bar = document.querySelector('.reading-progress');
      if (!bar) return;

      const stickyNav = document.querySelector('#sticky-nav');
      if (stickyNav) {
        stickyNav.append(bar);
      }
      if (!stickyNav) {
        bar.classList.add('reading-progress--fixed');
      }

      const updateProgress = () => {
        const scrollTop = globalThis.scrollY;
        const docHeight = document.documentElement.scrollHeight - globalThis.innerHeight;
        const progress = docHeight > 0 ? Math.min(scrollTop / docHeight, 1) : 0;
        bar.style.transform = `scaleX(${progress})`;
      };

      globalThis.addEventListener('scroll', updateProgress, { passive: true });
      updateProgress();
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initReadingProgress);
    } else {
      initReadingProgress();
    }
    document.addEventListener('astro:page-load', initReadingProgress);
  </script>
</Layout>
