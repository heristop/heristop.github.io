---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import ZenSlide from "../../components/zen/ZenSlide.astro";

const posts = await getCollection("blog");

const tagCounts = new Map<string, number>();
for (const post of posts) {
  const tags = post.data.tags ?? [];
  for (const tag of tags) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}

const sortedTags = [...tagCounts.entries()].toSorted((entryA, entryB) => entryA[0].localeCompare(entryB[0]));
const maxCount = Math.max(...tagCounts.values());
---

<Layout title="Tags" description="Browse blog posts by tag">
  <ZenSlide direction="up" delay={200}>
    <p class="tags-page__intro">
      Browse all topics covered in my reflections.
    </p>
  </ZenSlide>

  <div class="tags-page">
    <ZenSlide direction="up" delay={400}>
      <div class="tags-page__cloud">
        {sortedTags.map(([tag, count]) => {
          const weight = Math.min(count / maxCount, 1);
          const sizeClass = weight > 0.6 ? "tags-page__pill--lg" : weight > 0.25 ? "tags-page__pill--md" : "";
          return (
            <a
              class={`tags-page__pill ${sizeClass}`}
              href={`/tags/${tag}/`}
            >
              <span class="tags-page__pill-name">{tag}</span>
              <span class="tags-page__pill-count">{count}</span>
            </a>
          );
        })}
      </div>
    </ZenSlide>

    {sortedTags.length === 0 && (
      <ZenSlide direction="up" delay={400}>
        <p class="tags-page__empty">No tags found.</p>
      </ZenSlide>
    )}
  </div>
</Layout>

<style>
  .tags-page__intro {
    text-align: center;
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }

  .tags-page__cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    max-width: 50rem;
    margin: 0 auto;
  }

  .tags-page__pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    background: color-mix(in oklch, var(--primary-color) 8%, transparent);
    border: 1px solid color-mix(in oklch, var(--primary-color) 12%, transparent);
    color: var(--link-color-secondary);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition:
      background-color var(--zen-duration-fast) var(--zen-ease-out),
      border-color var(--zen-duration-fast) var(--zen-ease-out),
      color var(--zen-duration-fast) var(--zen-ease-out),
      transform var(--zen-duration-fast) var(--zen-ease-out);

    &::after {
      content: none;
    }

    &:hover {
      background: color-mix(in oklch, var(--primary-color) 16%, transparent);
      border-color: color-mix(in oklch, var(--primary-color) 28%, transparent);
      color: var(--primary-color);
      transform: translateY(-2px);
    }

    &:active {
      transform: scale(0.97);
      transition-duration: 80ms;
    }

    &:focus-visible {
      outline: 2px solid var(--primary-color);
      outline-offset: 2px;
    }
  }

  .tags-page__pill--md {
    font-size: 0.95rem;
    padding: 0.4rem 1rem;
    font-weight: 600;
  }

  .tags-page__pill--lg {
    font-size: 1.05rem;
    padding: 0.45rem 1.15rem;
    font-weight: 600;
    background: color-mix(in oklch, var(--primary-color) 12%, transparent);
    border-color: color-mix(in oklch, var(--primary-color) 18%, transparent);
  }

  .tags-page__pill-count {
    font-size: 0.7em;
    padding: 0.1rem 0.35rem;
    border-radius: 999px;
    background: color-mix(in oklch, var(--primary-color) 10%, transparent);
    color: var(--text-secondary);
    font-weight: 500;
    min-width: 1.2em;
    text-align: center;
  }

  .tags-page__empty {
    text-align: center;
    color: var(--text-secondary);
    padding: var(--space-xl);
  }
</style>
