---
interface Props {
  delay?: number;
  duration?: 'fast' | 'normal' | 'slow';
  className?: string;
  [key: string]: unknown;
}

const {
  delay = 0,
  duration = 'normal',
  className = '',
  ...rest
} = Astro.props;

const delayClass = delay > 0 ? `zen-delay-${delay}` : ''; // eslint-disable-line no-ternary
const durationClass = duration === 'normal' ? '' : `zen-duration-${duration}`; // eslint-disable-line no-ternary
---

<div
  class={`zen-fade ${delayClass} ${durationClass} ${className}`}
  {...rest}
>
  <slot />
</div>