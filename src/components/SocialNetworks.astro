---
import { Image } from "astro:assets";
import { LINKFOLIO_URL } from "../consts";

type NetworkIcon = { src?: string } | string | undefined;

interface NetworkType {
  title: string;
  description: string;
  url: string;
  group: string;
  iconSrc: NetworkIcon;
}

interface UserConfig {
  socialNetworks?: NetworkType[];
}

const fetchUserConfig = async (): Promise<UserConfig> => {
  try {
    const response = await fetch(`${LINKFOLIO_URL}/api/config`);

    if (!response.ok) {
      throw new Error(`Request failed with status ${response.status}`);
    }

    return await response.json();
  } catch (error) {
    if (import.meta.env.DEV) {
      console.warn("Unable to load remote social networks:", error);
    }

    return { socialNetworks: [] };
  }
};

const { filter, variant = 'default', baseDelay = 0 } = Astro.props;

const userConfig = await fetchUserConfig();
const networks = (userConfig.socialNetworks ?? []).filter(
  (network: NetworkType) => network.group === filter
);

if (variant === 'compact') {
  const order = ['X', 'BlueSky', 'Instagram', 'GitHub', 'LinkedIn'];
  networks.sort((a: NetworkType, b: NetworkType) => {
    const ai = order.indexOf(a.title);
    const bi = order.indexOf(b.title);
    return (ai === -1 ? 999 : ai) - (bi === -1 ? 999 : bi);
  });
}

const resolveIconSrc = (iconSrc: NetworkIcon) => {
  if (!iconSrc) {
    return "";
  }

  if (typeof iconSrc === "string") {
    return `${LINKFOLIO_URL}/${iconSrc}`;
  }

  if (iconSrc.src) {
    return `${LINKFOLIO_URL}/${iconSrc.src}`;
  }

  return "";
};

const STAGGER_STEP_MS = 120;
const STAGGER_MAX_INDEX = 5;

---

<section class={`social-network ${filter === 'project' ? 'social-network--projects' : ''} ${variant === 'compact' ? 'social-network--compact' : ''}`} style={`--social-count: ${networks.length}`}>
  {
    networks.length > 0 ? (
      networks.map((network: NetworkType, index: number) => {
        const isFeatured = variant === 'compact' ? false : index < 2;
        const modifier = isFeatured ? 'social-network__card--featured' : 'social-network__card--standard';
        const imgWidth = isFeatured ? 400 : 300;
        const imgHeight = isFeatured ? 200 : 100;
        return (
          <div
            class={`social-network__card ${modifier}`}
            style={`--social-card-stagger: ${baseDelay + STAGGER_STEP_MS * Math.min(index, STAGGER_MAX_INDEX)}ms`}
            data-prepared="false"
          >
            <a href={network.url} target="_blank" rel="noopener noreferrer" class="social-network__link">
              <div class="social-network__image-shell">
                <Image
                  src={resolveIconSrc(network.iconSrc)}
                  alt={network.description}
                  width={imgWidth}
                  height={imgHeight}
                  class="social-network__image"
                  loading="lazy"
                />
              </div>

              <div class="social-network__content">
                <h3 class="social-network__title">{network.title}</h3>
                <p class="social-network__description">{network.description}</p>
              </div>
            </a>
          </div>
        );
      })
    ) : (
      <p class="social-network__empty">No links available yet.</p>
    )
  }
</section>

{networks.length > 0 && (
  <script type="module" is:inline>
    const reveal = (card) => {
      requestAnimationFrame(() => {
        card.classList.add('social-network__card--visible');
      });
    };

    const prepare = (card) => {
      card.dataset.prepared = 'true';
    };

    const revealSocialCards = () => {
      const cards = document.querySelectorAll(
        '.social-network__card[data-prepared="false"]'
      );

      if (cards.length === 0) {
        return;
      }

      if ('IntersectionObserver' in globalThis) {
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                const card = entry.target;
                reveal(card);
                observer.unobserve(card);
              }
            }
          },
          {
            rootMargin: '0px 0px 100px 0px',
            threshold: 0.05,
          }
        );

        for (const card of cards) {
          prepare(card);
          observer.observe(card);
        }
      } else {
        for (const card of cards) {
          prepare(card);
          reveal(card);
        }
      }
    };

    const TILT_MAX = 6;

    const setupCardInteractions = () => {
      const cards = document.querySelectorAll('.social-network__card');

      for (const card of cards) {
        if (card.dataset.interactive === 'true') continue;
        card.dataset.interactive = 'true';

        card.addEventListener('mousemove', (e) => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          const centerX = rect.width / 2;
          const centerY = rect.height / 2;

          /* Glow position */
          card.style.setProperty('--glow-x', `${x}px`);
          card.style.setProperty('--glow-y', `${y}px`);

          /* 3D tilt */
          const rotateX = ((y - centerY) / centerY) * -TILT_MAX;
          const rotateY = ((x - centerX) / centerX) * TILT_MAX;
          card.style.setProperty('--tilt-x', `${rotateX}deg`);
          card.style.setProperty('--tilt-y', `${rotateY}deg`);

          card.classList.add('social-network__card--hover');
        });

        card.addEventListener('mouseleave', () => {
          card.classList.remove('social-network__card--hover');
          card.style.setProperty('--tilt-x', '0deg');
          card.style.setProperty('--tilt-y', '0deg');
        });
      }
    };

    if (typeof globalThis !== 'undefined') {
      revealSocialCards();
      setupCardInteractions();
      document.addEventListener('astro:page-load', () => {
        revealSocialCards();
        setupCardInteractions();
      });
    }
  </script>
)}
