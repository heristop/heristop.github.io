---
import {
  BLUESKY_URL,
  GITHUB_URL,
  LINKEDIN_URL,
  LINKFOLIO_URL,
  SITE_AUTHOR,
  SITE_PSEUDO,
  SITE_THEME,
  SITE_TITLE,
  X_URL,
} from '../consts';
import Icon from './Icon.astro';

const currentYear = new Date().getFullYear();
const brandMark = `{ ${SITE_TITLE.replace(' ', '_')} }`;

const normalizePath = (p: string) => (p === '/' ? '/' : p.replace(/\/$/, ''));
const currentPath = normalizePath(Astro.url.pathname);

const navEntries: { href: string; icon: string; label: string }[] = [
  { href: '/', icon: 'home', label: 'Home' },
  { href: '/blog', icon: 'book-open', label: 'Blog' },
  { href: '/projects', icon: 'layers', label: 'Projects' },
  { href: '/about', icon: 'info', label: 'About' },
  { href: '/path', icon: 'map', label: 'Path' },
];

const visibleNavEntries = navEntries.filter((entry) => normalizePath(entry.href) !== currentPath);
---

<footer class="site-footer" role="contentinfo">
  <button
    type="button"
    class="site-footer__eof"
    aria-label="Scroll to top"
    data-tooltip="↑ Back to top"
    data-scroll-top
  >
    <span class="site-footer__eof-bracket" aria-hidden="true">--</span><span
      class="site-footer__eof-text" aria-hidden="true">eof</span><span
      class="site-footer__eof-bracket" aria-hidden="true">--</span>
  </button>
  <div class="site-footer__container">
    <!-- About Section -->
    <section
      class="site-footer__section site-footer__about"
      aria-labelledby="footer-about"
    >
      <a
        href="/about"
        class="site-footer__profile"
        aria-label="About me"
        data-tooltip="About me"
        data-tooltip-placement="bottom"
      >
      </a>
      <div class="site-footer__info">
        <h3 id="footer-about" class="site-footer__title">{SITE_TITLE}</h3>
        <address class="site-footer__contact">
          <p class="site-footer__author">
            <span class="site-footer__meta-chip" aria-hidden="true">
              <Icon name="user" size={14} aria-hidden={true} />
            </span>
            <span class="site-footer__author-text">
              <span class="site-footer__author-name">{SITE_AUTHOR}</span>
              <span class="site-footer__handle">@{SITE_PSEUDO}</span>
            </span>
          </p>
          <p class="site-footer__role">
            <span class="site-footer__meta-chip" aria-hidden="true">
              <Icon name="feather" size={14} aria-hidden={true} />
            </span>
            <span>{SITE_THEME}</span>
          </p>
        </address>
      </div>
    </section>

    <!-- Navigation Section -->
    <section
      class="site-footer__section site-footer__nav"
      aria-labelledby="footer-nav"
    >
      <h3 id="footer-nav" class="site-footer__section-title">Navigate</h3>
      <nav aria-label="Footer navigation">
        <ul class="site-footer__nav-list">
          {
            visibleNavEntries.map((entry) => (
              <li>
                <a href={entry.href} class="site-footer__nav-link">
                  <span class="site-footer__nav-icon" aria-hidden="true">
                    <Icon name={entry.icon} size={14} aria-hidden={true} />
                  </span>
                  <span class="site-footer__nav-label">{entry.label}</span>
                  <Icon name="arrow-right" size={14} class="site-footer__nav-arrow" aria-hidden={true} />
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </section>

    <!-- Social & Links Section -->
    <section
      class="site-footer__section site-footer__social"
      aria-labelledby="footer-social"
    >
      <h3 id="footer-social" class="site-footer__section-title">Connect</h3>

      <!-- Social Media -->
      <div class="site-footer__social-links">
        <a
          href={GITHUB_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="site-footer__social-link"
          aria-label="GitHub Profile"
          data-tooltip="GitHub"
        >
          <img src="/icons/github.svg" alt="GitHub" width="20" height="20" />
        </a>
        <a
          href={LINKEDIN_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="site-footer__social-link"
          aria-label="LinkedIn Profile"
          data-tooltip="LinkedIn"
        >
          <img
            src="/icons/linkedin.svg"
            alt="LinkedIn"
            width="20"
            height="20"
          />
        </a>
        <a
          href={X_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="site-footer__social-link"
          aria-label="X (Twitter) Profile"
          data-tooltip="X (Twitter)"
        >
          <img src="/icons/x-twitter.svg" alt="X" width="20" height="20" />
        </a>
        <a
          href={BLUESKY_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="site-footer__social-link"
          aria-label="Bluesky Profile"
          data-tooltip="Bluesky"
        >
          <img src="/icons/bluesky.svg" alt="Bluesky" width="20" height="20" />
        </a>
      </div>

      <!-- Other Links -->
      <div class="site-footer__other-links">
        <a
          href={LINKFOLIO_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="site-footer__link"
          data-tooltip="All my socials on one page (opens in new tab)"
          data-tooltip-placement="top"
        >
          <span class="site-footer__link-icon" aria-hidden="true">
            <Icon name="external-link" size={14} aria-hidden={true} />
          </span>
          <span class="site-footer__link-label">Link in Bio</span>
          <Icon name="arrow-up-right" size={14} class="site-footer__link-arrow" aria-hidden={true} />
        </a>
        <button
          type="button"
          class="site-footer__link site-footer__rss-copy"
          data-url="/rss.xml"
          data-tooltip="Click to copy feed URL"
          data-tooltip-placement="top"
        >
          <span class="site-footer__link-icon" aria-hidden="true">
            <Icon name="rss" size={14} aria-hidden={true} />
          </span>
          <span class="site-footer__link-label">RSS Feed</span>
          <Icon name="copy" size={14} class="site-footer__link-arrow" aria-hidden={true} />
        </button>
      </div>
    </section>
  </div>

  <!-- Copyright -->
  <div class="site-footer__bottom">
    <p class="site-footer__copyright">
      <span class="site-footer__copyright-year">© 2014&ndash;{currentYear}</span>
      <span class="site-footer__copyright-sep" aria-hidden="true">·</span>
      <span class="site-footer__copyright-brand">{brandMark}</span>
      <span class="site-footer__copyright-sep" aria-hidden="true">·</span>
      <span class="site-footer__copyright-tag">
        <Icon name="feather" size={12} class="site-footer__copyright-icon" aria-hidden={true} />
        <em>zen-crafted</em>
      </span>
    </p>
  </div>
</footer>

<script is:inline>
  const initFooterRssCopy = () => {
    for (const el of document.querySelectorAll('.site-footer__rss-copy')) {
      const btn = el;
      if (btn.dataset.initialized === 'true') return;
      btn.dataset.initialized = 'true';
      btn.addEventListener('click', async () => {
        const url = new URL(btn.dataset.url || '/rss.xml', globalThis.location.origin).href;
        await navigator.clipboard.writeText(url);
        const label = btn.querySelector('span');
        if (!label) return;
        const original = label.textContent;
        label.textContent = 'Copied!';
        setTimeout(() => { label.textContent = original; }, 2000);
      });
    }
  };
  initFooterRssCopy();
  document.addEventListener('astro:page-load', initFooterRssCopy);
</script>

<script is:inline>
  const SCROLL_TOP_THRESHOLD = 400;

  const scrollToPageTop = () => {
    globalThis.scrollTo({ top: 0, behavior: 'smooth' });
  };

  const initScrollTopControls = () => {
    for (const el of document.querySelectorAll('[data-scroll-top]')) {
      if (el.dataset.scrollTopInit === 'true') {
        continue;
      }
      el.dataset.scrollTopInit = 'true';
      el.addEventListener('click', scrollToPageTop);
    }

    const fixedBtn = document.querySelector('.scroll-to-top[data-scroll-top-fixed]');
    if (fixedBtn && fixedBtn.dataset.scrollTopFixedInit !== 'true') {
      fixedBtn.dataset.scrollTopFixedInit = 'true';

      const updateFixedVisibility = () => {
        fixedBtn.toggleAttribute('hidden', globalThis.scrollY <= SCROLL_TOP_THRESHOLD);
      };

      globalThis.addEventListener('scroll', updateFixedVisibility, { passive: true });
      updateFixedVisibility();
      fixedBtn.addEventListener('click', scrollToPageTop);
    }
  };

  initScrollTopControls();
  document.addEventListener('astro:page-load', initScrollTopControls);
</script>
