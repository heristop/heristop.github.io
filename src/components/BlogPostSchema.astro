---
interface Props {
  title: string;
  description: string;
  pubDate?: Date;
  updatedDate?: Date;
  image?: string;
  url: string;
}

const { title, description, pubDate, updatedDate, image, url } = Astro.props;

const siteUrl = 'https://heristop.github.io';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  author: {
    '@type': 'Person',
    name: 'Alexandre Mogère',
    url: `${siteUrl}/about`,
  },
  dateModified: (updatedDate ?? pubDate)?.toISOString(),
  datePublished: pubDate?.toISOString(),
  description: description,
  headline: title,
  image: image ? new URL(image, siteUrl).toString() : undefined,
  mainEntityOfPage: {
    '@id': url,
    '@type': 'WebPage',
  },
  publisher: {
    '@type': 'Organization',
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/favicon.svg`,
    },
    name: 'Alexandre Mogère',
    url: siteUrl,
  },
  url: url,
};

// Remove undefined values
const cleanSchema = structuredClone(schema);
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(cleanSchema)} />
