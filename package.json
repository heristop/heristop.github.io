{
  "name": "zazencode",
  "type": "module",
  "version": "2.1.0",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "prepare": "husky",
    "lint": "oxlint src --type-aware -c oxlintrc.json",
    "lint:fix": "oxlint --fix src -c oxlintrc.json",
    "lint:strict": "oxlint src --deny-warnings --type-aware -c oxlintrc.json",
    "style:lint": "stylelint 'src/**/*.css' 'src/**/*.scss'",
    "md:lint": "markdownlint src/content/**/*.md --ignore node_modules --disable=MD013 --disable=MD033",
    "md:check": "markdown-link-check src/content/**/*.md --ignore node_modules -c .markdown-link-check.json",
    "format": "prettier --write 'src/**/*.ts'",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "test:visual:ui": "playwright test --ui",
    "test:visual:headed": "playwright test --headed",
    "optimize:images": "node scripts/optimize-images.mjs",
    "optimize:images:dry": "node scripts/optimize-images.mjs --dry-run"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/markdown-remark": "^7.1.0",
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/react": "^5.0.2",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@chenglou/pretext": "^0.0.3",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.1.1",
    "astro-icon": "^1.1.5",
    "katex": "^0.16.44",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype": "^13.0.2",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-math": "^6.0.0",
    "typescript": "^5.9.3",
    "unist-util-visit": "^5.1.0",
    "vite": "^8.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/hast": "^3.0.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "markdown-link-check": "3.14.2",
    "markdownlint-cli": "^0.48.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.18.1",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "sass": "^1.98.0",
    "sharp": "^0.34.5",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0"
  }
}
